{
  "meta": {
    "lastTouchedVersion": "2026.3.11",
    "lastTouchedAt": "2026-03-14T19:17:30.544Z"
  },
  "wizard": {
    "lastRunAt": "2026-03-13T08:42:04.585Z",
    "lastRunVersion": "2026.3.11",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "update": {
    "auto": {
      "enabled": true
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      },
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3.1-flash-lite-preview"
      },
      "models": {
        "google/gemini-3.1-pro-preview": {},
        "google/gemini-2.5-pro-preview-06-05": {},
        "openrouter/arcee-ai/trinity-large-preview:free": {},
        "openrouter/nvidia/nemotron-3-nano-30b-a3b:free": {},
        "openrouter/qwen/qwen3-coder:free": {},
        "openrouter/qwen/qwen3-next-80b-a3b-instruct:free": {},
        "openrouter/google/gemma-3-27b-it:free": {},
        "openrouter/openrouter/free": {},
        "openai/gpt-4o": {},
        "google/gemini-2.5-flash-preview-09-2025": {},
        "google/gemini-3.1-flash-lite-preview": {},
        "google/gemini-3-flash-preview": {},
        "openai/gpt-5.4": {}
      },
      "workspace": "/data/.openclaw/workspace"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Agent",
        "workspace": "/data/.openclaw/workspace",
        "agentDir": "/data/.openclaw/agents/main/agent",
        "model": {
          "primary": "google/gemini-3.1-flash-lite-preview"
        },
        "tools": {
          "profile": "coding",
          "alsoAllow": [
            "message",
            "tts",
            "browser",
            "web_search",
            "web_fetch",
            "agents_list",
            "canvas",
            "nodes"
          ]
        }
      }
    ]
  },
  "tools": {
    "profile": "full"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "enabled": true,
    "path": "/hooks",
    "token": "${WEBHOOK_TOKEN}",
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": [
      "hook:"
    ],
    "presets": [
      "gmail"
    ],
    "mappings": [
      {
        "match": {
          "path": "gmail"
        },
        "action": "agent",
        "wakeMode": "now",
        "name": "Gmail",
        "agentId": "main",
        "deliver": true,
        "channel": "last",
        "transform": {
          "module": "gmail/gmail-transform.mjs"
        }
      }
    ],
    "internal": {
      "enabled": true,
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-railway-template-production-2741.up.railway.app"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "127.0.0.1"
    ],
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "usage-tracker"
    ],
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "usage-tracker": {
        "enabled": true
      }
    }
  }
}
