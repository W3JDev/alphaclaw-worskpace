  },
  "tools": {
    "profile": "full"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "trustedProxies": [
      "127.0.0.1"
    ],
    "controlUi": {
      "allowedOrigins": [
        "https://openclaw-railway-template-production-2741.up.railway.app"
      ]
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    }
  },
  "plugins": {
    "allow": [
      "telegram",
      "usage-tracker"
    ]
  },
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "usage-tracker": {
        "enabled": true
      }
    }
  },
  "hooks": {
    "internal": {
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      },
      "enabled": true
    },
    "enabled": true,
    "token": "${WEBHOOK_TOKEN}",
    "presets": [
      "gmail"
    ],
    "mappings": [
      {
        "match": {
          "path": "gmail"
        },
        "action": "agent",
        "name": "Gmail",
        "wakeMode": "now",
        "transform": {
          "module": "gmail/gmail-transform.mjs"
        },
        "deliver": true,
        "channel": "last",
        "agentId": "main"
      }
    ],
    "path": "/hooks",
    "defaultSessionKey": "hook:ingress",
    "allowRequestSessionKey": false,
    "allowedSessionKeyPrefixes": [
      "hook:"
    ]
  }
}